# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Turath Masr
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_COMPANY_DOMAIN=

# ─── VPS Deployment ───────────────────────────────────────────────────────────
# Used by deploy_vps.sh — set these before running the deploy script.
VPS_IP=
VPS_USER=
VPS_PATH=
APP_PORT=
# Optional — override only when running a parallel staging deploy.
# Defaults to "turath-masr" (the production process name) when unset.
# Example: PM2_APP_NAME=turath-staging
PM2_APP_NAME=

# ─── Finalize Deploy ──────────────────────────────────────────────────────────
# Used by finalize_deploy.sh on the remote server.
APP_PATH=
