# ─── Environment files — NEVER commit these ───────────────────────────────────
.env
.env.local
.env.production
.env.development
.env.test
.env.*.local

# ─── Security / certificates ───────────────────────────────────────────────────
*.pem
*.key
*.crt

# ─── Backup files — use git history instead ────────────────────────────────────
*.bak
*.backup
*.old

# ─── Node modules ──────────────────────────────────────────────────────────────
node_modules/
package-lock.json

# ─── Next.js build output ──────────────────────────────────────────────────────
.next/
out/
dist/

# ─── Production build ──────────────────────────────────────────────────────────
build/

# ─── Logs ──────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ─── OS-specific files ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Vercel deployment ─────────────────────────────────────────────────────────
.vercel/

# ─── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── Testing ───────────────────────────────────────────────────────────────────
coverage/
jest-test-results.json

# ─── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/

# ─── Local Supabase backups (NEVER commit — contain customer data) ─────────────
.backups/
prod_*.sql

# ─── Supabase CLI runtime artifacts ────────────────────────────────────────────
# (the supabase/ subdir has its own .gitignore for these too;
#  duplicating here as defense-in-depth)
supabase/.branches/
supabase/.temp/

# ─── Local production schema baseline (never commit) ───────────────────────────
supabase/migrations/20260101000000_schema_baseline_from_production.sql
